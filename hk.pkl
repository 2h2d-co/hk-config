amends "package://github.com/jdx/hk/releases/download/v1.50.0/hk@1.50.0#/Config.pkl"

import "./Base.pkl" as Base
import "./GitHubActions.pkl" as GitHubActions
import "./Shell.pkl" as Shell

local repoSteps = new Mapping<String, Step> {
  ["pkl-eval"] {
    glob = List("*.pkl")
    check = "for f in {{files}}; do pkl eval \"$f\" >/dev/null; done"
  }
}

local projectSteps = (Base.baseSteps) {
  ...GitHubActions.gitHubActionsSteps
  ...Shell.shellSteps
  ...repoSteps
}

display_skip_reasons = Base.displaySkipReasons
hooks = new Mapping<String, Hook> {
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps = projectSteps
  }
  ["pre-push"] {
    steps = projectSteps
  }
  ["commit-msg"] {
    steps = Base.commitMessageSteps
  }
  ["fix"] {
    fix = true
    steps = projectSteps
  }
  ["check"] {
    steps = projectSteps
  }
}
