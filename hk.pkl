amends "./Base.pkl"
import "./Base.pkl" as Base
import "./GitHubActions.pkl" as GitHubActions
import "./Shell.pkl" as Shell

local repoSteps = new Mapping<String, Step> {
  ["hk-config-validate"] {
    glob = List("*.pkl")
    check = "for f in {{files}}; do HK_FILE=\"$f\" hk validate; done"
  }
}

hooks = Base.defaultHooks(true, (Base.baseSteps) {
  ...GitHubActions.gitHubActionsSteps
  ...Shell.shellSteps
  ...repoSteps
})
