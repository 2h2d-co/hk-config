import "package://github.com/jdx/hk/releases/download/v1.50.0/hk@1.50.0#/Config.pkl" as Config
import "package://github.com/jdx/hk/releases/download/v1.50.0/hk@1.50.0#/Builtins.pkl"

// Show when conditional steps are skipped because profiles or command/file conditions do not match.
displaySkipReasons = List("profile-not-enabled", "condition-false")

commitMessageSteps = new Mapping<String, Config.Step> {
  ["cocogitto-commit-msg"] = (Builtins.cocogitto_commit_msg) {
    step_condition = "exec('command -v cog >/dev/null 2>&1; echo $?') == '0\n'"
  }
  ["check-conventional-commit"] = (Builtins.check_conventional_commit) {
    step_condition = "exec('command -v cog >/dev/null 2>&1; echo $?') != '0\n'"
    check = "hk util check-conventional-commit --allowed-types=build,chore,ci,docs,feat,fix,perf,refactor,revert,style,test,release \"{{commit_msg_file}}\""
  }
}

baseSteps = new Mapping<String, Config.Step> {
  ["check-added-large-files"] = Builtins.check_added_large_files
  ["check-case-conflict"] = Builtins.check_case_conflict
  ["check-executables-have-shebangs"] = Builtins.check_executables_have_shebangs
  ["check-merge-conflict"] = Builtins.check_merge_conflict
  ["check-symlinks"] = Builtins.check_symlinks
  ["byte-order-marker"] = Builtins.byte_order_marker
  ["mixed-line-ending"] = Builtins.mixed_line_ending
  ["newlines"] = Builtins.newlines
  ["trailing-whitespace"] = Builtins.trailing_whitespace
  ["detect-private-key"] = Builtins.detect_private_key

  ["gitleaks"] = (Builtins.gitleaks) {
    step_condition = "exec('command -v gitleaks >/dev/null 2>&1; echo $?') == '0\n'"
  }
  ["mise-installed"] {
    step_condition = "exec('test -f \"mise.toml\"; echo $?') == '0\n'"
    check = "mise --version >/dev/null 2>&1"
  }
  ["mise"] = (Builtins.mise) {
    step_condition = "exec('test -f \"mise.toml\"; echo $?') == '0\n'"
    depends = List("mise-installed")
  }
}
