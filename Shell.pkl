amends "./Base.pkl"
import "package://github.com/jdx/hk/releases/download/v1.48.0/hk@1.48.0#/Builtins.pkl"
import "./Base.pkl" as Base

shellSteps = new Mapping<String, Step> {
  ["shfmt"] = (Base.optionalCommand("shfmt", Builtins.shfmt)) {
    glob = List("**/*.sh", "**/*.bash")
  }
  ["shellcheck"] = (Base.optionalCommand("shellcheck", Builtins.shellcheck)) {
    depends = List("shfmt")
  }
}

hooks = Base.defaultHooks(true, (Base.baseSteps) {
  ...shellSteps
})
