import "package://github.com/jdx/hk/releases/download/v1.51.0/hk@1.51.0#/Config.pkl" as Config
import "package://github.com/jdx/hk/releases/download/v1.51.0/hk@1.51.0#/Builtins.pkl"
import "./Base.pkl" as Base

shellSteps = new Mapping<String, Config.Step> {
  ["shfmt"] = (Base.optionalCommand("shfmt", Builtins.shfmt)) {
    match_any = List(
      new Config.FileSelector { glob = List("**/*.sh", "**/*.bash") },
    )
  }
  ["shellcheck"] = (Base.optionalCommand("shellcheck", Builtins.shellcheck)) {
    depends = List("shfmt")
  }
}
