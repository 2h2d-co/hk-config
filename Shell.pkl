import "package://github.com/jdx/hk/releases/download/v1.50.0/hk@1.50.0#/Config.pkl" as Config
import "package://github.com/jdx/hk/releases/download/v1.50.0/hk@1.50.0#/Builtins.pkl"

shellSteps = new Mapping<String, Config.Step> {
  ["shfmt"] = (Builtins.shfmt) {
    step_condition = "exec('command -v shfmt >/dev/null 2>&1; echo $?') == '0\n'"
    glob = List("**/*.sh", "**/*.bash")
  }
  ["shellcheck"] = (Builtins.shellcheck) {
    step_condition = "exec('command -v shellcheck >/dev/null 2>&1; echo $?') == '0\n'"
    depends = List("shfmt")
  }
}
