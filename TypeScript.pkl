import "package://github.com/jdx/hk/releases/download/v1.51.0/hk@1.51.0#/Config.pkl" as Config
import "package://github.com/jdx/hk/releases/download/v1.51.0/hk@1.51.0#/Builtins.pkl"
import "./Base.pkl" as Base

typeScriptSteps = new Mapping<String, Config.Step> {
  ["oxfmt"] = (Base.optionalCommand("oxfmt", Builtins.oxfmt)) {
    check = "oxfmt --check --no-error-on-unmatched-pattern {{files}}"
    check_list_files = "oxfmt --list-different --no-error-on-unmatched-pattern {{files}}"
    fix = "oxfmt --write --no-error-on-unmatched-pattern {{files}}"
  }
  ["oxlint"] = Base.optionalCommand("oxlint", Builtins.ox_lint)
  ["tsc"] = Base.optionalCommand("tsc", Builtins.tsc)
}
