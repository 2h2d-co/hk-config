import "package://github.com/jdx/hk/releases/download/v1.50.0/hk@1.50.0#/Config.pkl" as Config
import "package://github.com/jdx/hk/releases/download/v1.50.0/hk@1.50.0#/Builtins.pkl"

typeScriptSteps = new Mapping<String, Config.Step> {
  ["oxfmt"] = (Builtins.oxfmt) {
    exclude = List("**/*.md", "**/*.mdx")
    step_condition = "exec('command -v oxfmt >/dev/null 2>&1; echo $?') == '0\n'"
  }
  ["oxlint"] = (Builtins.ox_lint) {
    step_condition = "exec('command -v oxlint >/dev/null 2>&1; echo $?') == '0\n'"
  }
  ["tsc"] = (Builtins.tsc) {
    step_condition = "exec('command -v tsc >/dev/null 2>&1; echo $?') == '0\n'"
  }
}
