amends "./Base.pkl"
import "package://github.com/jdx/hk/releases/download/v1.48.0/hk@1.48.0#/Builtins.pkl"
import "./Base.pkl" as Base

gitHubActionsSteps = new Mapping<String, Step> {
  ["actionlint"] = Base.optionalCommand("actionlint", Builtins.actionlint)
  ["zizmor"] = Base.optionalCommand(
    "zizmor",
    (Builtins.zizmor) {
      check_diff = "zizmor --no-progress --pedantic {{ files }}"
      fix = "zizmor --no-progress --pedantic --fix {{ files }}"
    },
  )
}

hooks = Base.defaultHooks(true, (Base.baseSteps) {
  ...gitHubActionsSteps
})
