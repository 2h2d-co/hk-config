import "package://github.com/jdx/hk/releases/download/v1.51.0/hk@1.51.0#/Config.pkl" as Config
import "package://github.com/jdx/hk/releases/download/v1.51.0/hk@1.51.0#/Builtins.pkl"
import "./Base.pkl" as Base

goSteps = new Mapping<String, Config.Step> {
  ["go-imports"] = Base.optionalCommand("goimports", Builtins.go_imports)
  ["go-fmt"] = (Base.optionalCommand("gofmt", Builtins.go_fmt)) {
    depends = List("go-imports")
  }
  ["gomod-tidy"] = Base.optionalCommand("go", Builtins.gomod_tidy)
  ["go-vet"] = (Base.optionalCommand("go", Builtins.go_vet)) {
    depends = List("go-fmt", "gomod-tidy")
  }
  ["golangci-lint"] = (Base.optionalCommand("golangci-lint", Builtins.golangci_lint)) {
    depends = List("go-fmt", "gomod-tidy")
  }
  ["go-vuln-check"] = (Base.optionalCommand("govulncheck", Builtins.go_vuln_check)) {
    depends = List("go-vet")
  }
}
